# ============================================================================
# EduLattice Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual secret values
# NEVER commit .env to version control
# ============================================================================

# ========== DATABASE ==========
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/edulattice

# ========== JWT AUTHENTICATION ==========
# Generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-minimum-32-characters-here-generate-random

# ========== CLOUDINARY INTEGRATION ==========
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ========== SERVER CONFIG ==========
NODE_ENV=development
PORT=5000

# ========== FRONTEND URLS ==========
# Comma-separated list of allowed frontend URLs
FRONTEND_URL=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Development-only origins (extra IPs for local network)
DEV_ORIGINS=http://localhost:5173,http://localhost:3000

# ========== SESSION SETTINGS ==========
# Session timeout in minutes (default: 20)
SESSION_TIMEOUT_MINUTES=20

# ========== RATE LIMITING ==========
# Rate limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Rate limit max attempts (default: 10)
RATE_LIMIT_MAX_ATTEMPTS=10

# ========== RENDER DEPLOYMENT ==========
# Required for Render.com deployment
RENDER_GIT_REPO=

# ========== OPTIONAL: EMAIL CONFIG ==========
# For future password reset/email verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# ========== OPTIONAL: REDIS CACHE ==========
# For advanced session/cache management
REDIS_URL=redis://localhost:6379

# ========== LOGGING ==========
# Log level: debug, info, warn, error
LOG_LEVEL=info

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/edulattice?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long_12345

# Node Environment
NODE_ENV=development

# Server Port
PORT=5000

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Development Origins (comma-separated)
DEV_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173

# Session Configuration
SESSION_TIMEOUT_MINUTES=20

# Rate Limiting (production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_ATTEMPTS=20
